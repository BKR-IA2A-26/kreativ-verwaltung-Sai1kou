@model IEnumerable<Apex_database.Models.HeilItem>

@{
    ViewData["Title"] = "Heil-Items Übersicht";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1" style="color: #da292a;">Heil- Und Unterstützungsitems</h1>
        <p class="text-muted small mb-0">Übersicht aller medizinischen Kits, Schildzellen und Phoenix-Kits</p>
    </div>
    <a asp-action="Create" class="btn btn-apex">+ Neues Heilitem</a>
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="table-responsive">
        <table class="table table-dark table-hover table-striped align-middle mb-0">
            <thead>
                <tr class="border-bottom border-secondary text-uppercase fs-7">
                    <th class="py-3 px-4" style="color: #da292a;">@Html.DisplayNameFor(model => model.Name)</th>
                    <th class="py-3" style="color: #da292a;">@Html.DisplayNameFor(model => model.HeilungHp)</th>
                    <th class="py-3" style="color: #da292a;">@Html.DisplayNameFor(model => model.HeilungSchild)</th>
                    <th class="py-3" style="color: #da292a;">@Html.DisplayNameFor(model => model.AnwendungsdauerSek)</th>
                    <th class="py-3 text-end px-4" style="color: #da292a;">Aktionen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="border-bottom border-secondary">
                        <td class="fw-bold text-light py-3 px-4 fs-5">@Html.DisplayFor(modelItem => item.Name)</td>
                        <td>
                            @if (item.HeilungHp >= 100)
                            {
                                <span class="badge bg-success px-2.5 py-1.5 fw-bold">💚 VOLLSTÄNDIG</span>
                            }
                            else if (item.HeilungHp > 0)
                            {
                                <span class="text-success fw-bold font-monospace">💚 +@item.HeilungHp HP</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (item.HeilungSchild >= 100)
                            {
                                <span class="badge bg-info text-dark px-2.5 py-1.5 fw-bold">🛡️ VOLLSTÄNDIG</span>
                            }
                            else if (item.HeilungSchild > 0)
                            {
                                <span class="text-info fw-bold font-monospace">🛡️ +@item.HeilungSchild Schild</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="text-light font-monospace">
                            ⏱️ @item.AnwendungsdauerSek Sek.
                        </td>
                        <td class="text-end px-4">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@item.HeilId" class="btn btn-outline-light border-secondary">Bearbeiten</a>
                                <a asp-action="Details" asp-route-id="@item.HeilId" class="btn btn-outline-info border-secondary">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.HeilId" class="btn btn-outline-danger border-secondary">Entfernen</a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">Keine medizinischen Vorräte in der Datenbank registriert.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
