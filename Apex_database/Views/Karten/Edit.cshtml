@model Apex_database.Models.Karte

@{
    ViewData["Title"] = "Karte modifizieren";
}

<style>
    .form-dark-control {
        background-color: #1a1a1a !important;
        border: 1px solid #333 !important;
        color: #fff !important;
    }
    .form-dark-control:focus {
        border-color: #da292a !important;
        box-shadow: 0 0 0 0.25rem rgba(218, 41, 42, 0.25) !important;
    }
</style>

<div class="mb-4">
    <h1 class="fw-bold mb-1" style="color: #da292a;">Koordinaten korrigieren</h1>
    <p class="text-muted small">Aktualisiere die Bezeichnung des Austragungsortes</p>
</div>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark border-secondary shadow p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="KarteId" />
                
                <div class="form-group mb-3">
                    <label class="control-label text-muted small fw-bold mb-1">Sektor ID (Verschlüsselt)</label>
                    <input class="form-control form-dark-control" value="🗺️ @Model.KarteId" disabled style="opacity: 0.5; cursor: not-allowed;" />
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Name" class="control-label text-muted small fw-bold mb-1">Zonen-Bezeichnung</label>
                    <input asp-for="Name" class="form-control form-dark-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-apex px-4">Aktualisieren</button>
                    <a asp-action="Index" class="btn btn-outline-light border-secondary px-4">Abbrechen</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
