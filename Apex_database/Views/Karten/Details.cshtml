@model Apex_database.Models.Karte

@{
    ViewData["Title"] = "Sektoren-Analyse";
}

<div class="mb-4">
    <h1 class="fw-bold mb-1" style="color: #da292a;">Topografischer Scan</h1>
    <p class="text-muted small">Systemdetails zum ausgewählten Sektor</p>
</div>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark border-secondary shadow mb-4">
            <div class="card-header border-bottom border-secondary bg-transparent py-3 px-4">
                <h5 class="mb-0 fw-bold text-light">🗺️ Kartendaten</h5>
            </div>
            <div class="card-body p-4">
                <div class="row mb-3">
                    <div class="col-4 text-muted small fw-bold text-uppercase">System ID:</div>
                    <div class="col-8 text-light font-monospace">#@Html.DisplayFor(model => model.KarteId)</div>
                </div>
                <hr class="border-secondary my-2" />
                <div class="row mb-2 mt-2">
                    <div class="col-4 text-muted small fw-bold text-uppercase">Bezeichnung:</div>
                    <div class="col-8 text-light fw-bold fs-4">@Html.DisplayFor(model => model.Name)</div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model?.KarteId" class="btn btn-apex px-4">Umbenennen</a>
            <a asp-action="Index" class="btn btn-outline-light border-secondary px-4">Zurück zur Übersicht</a>
        </div>
    </div>
</div>