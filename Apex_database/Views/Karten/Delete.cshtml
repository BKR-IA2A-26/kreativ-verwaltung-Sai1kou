@model Apex_database.Models.Karte

@{
    ViewData["Title"] = "Sektor sperren";
}

<div class="mb-4">
    <h1 class="fw-bold mb-1 text-danger">Einsatzgebiet ausbuchen</h1>
    <p class="text-muted small">Soll diese Karte dauerhaft aus der Rotations-Datenbank entfernt werden?</p>
</div>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark border-danger shadow mb-4" style="border-width: 1px; border-style: solid;">
            <div class="card-header border-bottom border-danger bg-transparent py-3 px-4">
                <h5 class="mb-0 fw-bold text-danger">⚠️ WARNUNG: OPERATIONS-ABBRUCH</h5>
            </div>
            <div class="card-body p-4">
                <div class="row mb-3">
                    <div class="col-4 text-muted small fw-bold text-uppercase">Sektor ID:</div>
                    <div class="col-8 text-muted font-monospace">#@Html.DisplayFor(model => model.KarteId)</div>
                </div>
                <hr class="border-secondary my-2" />
                <div class="row mb-2 mt-2">
                    <div class="col-4 text-muted small fw-bold text-uppercase">Areal-Name:</div>
                    <div class="col-8 text-light fw-bold fs-5">🗺️ @Html.DisplayFor(model => model.Name)</div>
                </div>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="KarteId" />
            <div class="d-flex gap-2">
                <input type="submit" value="Areal dauerhaft sperren" class="btn btn-danger px-4 fw-bold" />
                <a asp-action="Index" class="btn btn-outline-light border-secondary px-4">Abbrechen</a>
            </div>
        </form>
    </div>
</div>