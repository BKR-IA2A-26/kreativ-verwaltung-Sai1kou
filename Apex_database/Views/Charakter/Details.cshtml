@model Apex_database.Models.Charakter

@{
    ViewData["Title"] = "Legenden Details";
}

<div class="mb-4">
    <h1 class="fw-bold mb-1" style="color: #da292a;">Akte: @Html.DisplayFor(model => model.Name)</h1>
    <p class="text-muted small">Detailierte Profilübersicht aus dem Core-System</p>
</div>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark border-secondary shadow mb-4">
            <div class="card-header border-bottom border-secondary bg-transparent py-3 px-4">
                <h5 class="mb-0 fw-bold text-light">Melderegister-Daten</h5>
            </div>
            <div class="card-body p-4">
                <div class="row mb-3">
                    <div class="col-4 text-muted small fw-bold text-uppercase">Datenbank ID:</div>
                    <div class="col-8 text-light font-monospace">@Html.DisplayFor(model => model.CharakterId)</div>
                </div>
                <hr class="border-secondary my-2" />
                <div class="row mb-3 mt-2">
                    <div class="col-4 text-muted small fw-bold text-uppercase">Rufname:</div>
                    <div class="col-8 text-light fw-bold fs-5">@Html.DisplayFor(model => model.Name)</div>
                </div>
                <hr class="border-secondary my-2" />
                <div class="row mb-2 mt-2">
                    <div class="col-4 text-muted small fw-bold text-uppercase">Klassifizierung:</div>
                    <div class="col-8">
                        @{
                            var k = Model.Klasse?.ToLower() ?? "";
                            var badgeClass = "badge px-2.5 py-1.5 fw-semibold text-uppercase";
                            var badgeStyle = "";

                            if (k.Contains("angriff") || k.Contains("assault"))
                            {
                                badgeClass += " bg-danger";
                            }
                            else if (k.Contains("aufklärung") || k.Contains("recon"))
                            {
                                badgeClass += " bg-success";
                            }
                            else if (k.Contains("unterstützung") || k.Contains("support"))
                            {
                                badgeClass += " bg-info text-dark";
                            }
                            else if (k.Contains("controller") || k.Contains("kontrolle"))
                            {
                                badgeStyle = "background-color: #20c997; color: #121212;";
                            }
                            else if (k.Contains("skirmisher") || k.Contains("scharmützel"))
                            {
                                badgeClass += " bg-warning text-dark";
                            }
                            else
                            {
                                badgeClass += " bg-secondary";
                            }
                        }
                        <span class="@badgeClass" style="@badgeStyle">@Html.DisplayFor(model => model.Klasse)</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model?.CharakterId" class="btn btn-apex px-4">Bearbeiten</a>
            <a asp-action="Index" class="btn btn-outline-light border-secondary px-4">Zurück zur Liste</a>
        </div>
    </div>
</div>
