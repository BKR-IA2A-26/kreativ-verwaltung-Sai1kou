@model IEnumerable<Apex_database.Models.Aufsatz>

@{
    ViewData["Title"] = "Aufsätze";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1" style="color: #da292a;">Waffen-Aufsätze</h1>
        <p class="text-muted small mb-0">Verwaltung aller Attachments und Modifikationen</p>
    </div>
    <a asp-action="Create" class="btn btn-apex">+ Neuer Aufsatz</a>
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="table-responsive">
        <table class="table table-dark table-hover table-striped align-middle mb-0">
            <thead>
                <tr class="border-bottom border-secondary text-uppercase fs-7">
                    <th class="py-3 px-4" style="color: #da292a;">@Html.DisplayNameFor(model => model.Name)</th>
                    <th class="py-3" style="color: #da292a;">@Html.DisplayNameFor(model => model.Typ)</th>
                    <th class="py-3" style="color: #da292a;">@Html.DisplayNameFor(model => model.Seltenheit)</th>
                    <th class="py-3 text-end px-4" style="color: #da292a;">Aktionen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="border-bottom border-secondary">
                        <td class="fw-bold text-light py-3 px-4">@Html.DisplayFor(modelItem => item.Name)</td>
                        <td><span class="text-muted">@Html.DisplayFor(modelItem => item.Typ)</span></td>
                        <td>
                            @{
                                var s = item.Seltenheit?.ToLower();
                                var badgeColor = s == "legendär" || s == "gold" ? "bg-warning text-dark" :
                                s == "episch" || s == "lila" ? "bg-primary" :
                                s == "selten" || s == "blau" ? "bg-info text-dark" :
                                "bg-secondary";
                            }
                            <span class="badge @badgeColor px-2.5 py-1.5 fw-semibold">@Html.DisplayFor(modelItem => item.Seltenheit)</span>
                        </td>
                        <td class="text-end px-4">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@item.AufsatzId" class="btn btn-outline-light border-secondary">Bearbeiten</a>
                                <a asp-action="Details" asp-route-id="@item.AufsatzId" class="btn btn-outline-info border-secondary">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.AufsatzId" class="btn btn-outline-danger border-secondary">Löschen</a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">Keine Aufsätze in der Datenbank vorhanden.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
