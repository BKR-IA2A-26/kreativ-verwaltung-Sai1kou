@model Apex_database.Models.Faehigkeit

@{
    ViewData["Title"] = "Fähigkeit hinzufügen";
}

<style>
    .form-dark-control {
        background-color: #1a1a1a !important;
        border: 1px solid #333 !important;
        color: #fff !important;
    }

        .form-dark-control:focus {
            border-color: #da292a !important;
            box-shadow: 0 0 0 0.25rem rgba(218, 41, 42, 0.25) !important;
        }

    select.form-dark-control option {
        background-color: #1a1a1a;
        color: #fff;
    }
</style>

<div class="mb-4">
    <h1 class="fw-bold mb-1" style="color: #da292a;">Fähigkeit schmieden</h1>
    <p class="text-muted small">Registriere eine neue Fähigkeit und weise sie einer Legende zu</p>
</div>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark border-secondary shadow p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="FaehigkeitId" class="control-label text-muted small fw-bold mb-1">Fähigkeit ID</label>
                    <input asp-for="FaehigkeitId" class="form-control form-dark-control" placeholder="z.B. 101" />
                    <span asp-validation-for="FaehigkeitId" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CharakterId" class="control-label text-muted small fw-bold mb-1">Zugehörige Legende (Charakter)</label>
                    <select asp-for="CharakterId" class="form-control form-dark-control" asp-items="ViewBag.CharakterId"></select>
                    <span asp-validation-for="CharakterId" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label text-muted small fw-bold mb-1">Name der Fähigkeit</label>
                    <input asp-for="Name" class="form-control form-dark-control" placeholder="z.B. Void-Transit, Luftschlag..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Typ" class="control-label text-muted small fw-bold mb-1">Typ (Passiv / Taktisch / Ultimativ)</label>
                    <input asp-for="Typ" class="form-control form-dark-control" placeholder="z.B. Taktisch" />
                    <span asp-validation-for="Typ" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="CooldownSek" class="control-label text-muted small fw-bold mb-1">Cooldown (in Sekunden)</label>
                    <input asp-for="CooldownSek" class="form-control form-dark-control" placeholder="0 eingeben für Passiv" />
                    <span asp-validation-for="CooldownSek" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-apex px-4">Erstellen</button>
                    <a asp-action="Index" class="btn btn-outline-light border-secondary px-4">Abbrechen</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
