@model Apex_database.Models.Aufsatz

@{
    ViewData["Title"] = "Aufsatz löschen";
}

<div class="mb-4">
    <h1 class="fw-bold mb-1 text-danger">Aufsatz löschen</h1>
    <p class="text-muted small">Möchtest du diesen Eintrag wirklich permanent aus der Arena-Datenbank entfernen?</p>
</div>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark border-danger shadow mb-4" style="border-width: 1px; border-style: solid;">
            <div class="card-header border-bottom border-danger bg-transparent py-3 px-4">
                <h5 class="mb-0 fw-bold text-danger">⚠️ Warnung</h5>
            </div>
            <div class="card-body p-4">
                <div class="row mb-3">
                    <div class="col-4 text-muted small fw-bold text-uppercase">Name:</div>
                    <div class="col-8 text-light fw-bold">@Html.DisplayFor(model => model.Name)</div>
                </div>
                <hr class="border-secondary my-2" />
                <div class="row mb-3 mt-2">
                    <div class="col-4 text-muted small fw-bold text-uppercase">Typ:</div>
                    <div class="col-8 text-light">@Html.DisplayFor(model => model.Typ)</div>
                </div>
                <hr class="border-secondary my-2" />
                <div class="row mb-2 mt-2">
                    <div class="col-4 text-muted small fw-bold text-uppercase">Seltenheit:</div>
                    <div class="col-8 text-light">@Html.DisplayFor(model => model.Seltenheit)</div>
                </div>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="AufsatzId" />
            <div class="d-flex gap-2">
                <input type="submit" value="Endgültig Löschen" class="btn btn-danger px-4 fw-bold" />
                <a asp-action="Index" class="btn btn-outline-light border-secondary px-4">Abbrechen</a>
            </div>
        </form>
    </div>
</div>