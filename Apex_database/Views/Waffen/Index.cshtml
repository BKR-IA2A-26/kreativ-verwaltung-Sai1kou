@model IEnumerable<Apex_database.Models.Waffe>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.WaffenTyp)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BasisSchaden)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Munition)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.WaffenTyp)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.BasisSchaden)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Munition.MunitionId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.WaffeId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.WaffeId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.WaffeId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
