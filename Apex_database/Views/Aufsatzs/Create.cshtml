@model Apex_database.Models.Aufsatz

@{
    ViewData["Title"] = "Neuer Aufsatz";
}

<style>
    .form-dark-control {
        background-color: #1a1a1a !important;
        border: 1px solid #333 !important;
        color: #fff !important;
    }

        .form-dark-control:focus {
            border-color: #da292a !important;
            box-shadow: 0 0 0 0.25rem rgba(218, 41, 42, 0.25) !important;
        }
</style>

<div class="mb-4">
    <h1 class="fw-bold mb-1" style="color: #da292a;">Aufsatz registrieren</h1>
    <p class="text-muted small">Füge der Datenbank ein neues Waffen-Attachment hinzu</p>
</div>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark border-secondary shadow p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="AufsatzId" class="control-label text-muted small fw-bold mb-1">Aufsatz ID</label>
                    <input asp-for="AufsatzId" class="form-control form-dark-control" placeholder="z.B. 1" />
                    <span asp-validation-for="AufsatzId" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label text-muted small fw-bold mb-1">Name des Aufsatzes</label>
                    <input asp-for="Name" class="form-control form-dark-control" placeholder="z.B. Erweitertes Leichtes Magazin" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Typ" class="control-label text-muted small fw-bold mb-1">Typ / Slot</label>
                    <input asp-for="Typ" class="form-control form-dark-control" placeholder="z.B. Magazin, Visier, Schaft" />
                    <span asp-validation-for="Typ" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Seltenheit" class="control-label text-muted small fw-bold mb-1">Seltenheitsstufe</label>
                    <input asp-for="Seltenheit" class="form-control form-dark-control" placeholder="z.B. Gewöhnlich, Selten, Episch, Legendär" />
                    <span asp-validation-for="Seltenheit" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-apex px-4">Erstellen</button>
                    <a asp-action="Index" class="btn btn-outline-light border-secondary px-4">Abbrechen</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
